APP_NAME=NovaShop
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Flash sale & scheduled tasks: dùng giờ VN
APP_TIMEZONE=Asia/Ho_Chi_Minh

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Local: database | Production: redis (cần Redis server + ext-phpredis hoặc predis)
CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis — bật khi CACHE_STORE=redis và/hoặc SESSION_DRIVER=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=your@gmail.com
# MAIL_PASSWORD=your-16-char-app-password
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# SPA React: http://127.0.0.1:8000/spa — chạy `npm run dev` (Vite proxy /api → Laravel) và `php artisan serve`

# Render.com (Docker): APP_KEY, APP_ENV=production, APP_DEBUG=false, APP_URL=https://your-service.onrender.com
# DB: Port 5432 = PostgreSQL; port 3306 = MySQL. Laravel dùng engine khớp với DB_* / URL — không tự “đổi” MySQL sang 5432.
# Render PostgreSQL (host dpg-...): DB_CONNECTION=pgsql; DB_URL=${DATABASE_URL} nếu chỉ có DATABASE_URL.
# SSL: app tự dùng sslmode=require khi RENDER=true (tránh lỗi "SSL connection has been closed unexpectedly"). Ghi đè: DB_SSLMODE=prefer
# Muốn MySQL trên Render: dùng MySQL bên ngoài (PlanetScale, RDS, …), DB_CONNECTION=mysql, DB_PORT=3306, và xóa/ghi đè DATABASE_URL Postgres.
# Chưa có DB: SESSION_DRIVER=file để tránh lỗi session/cache database.

# Google OAuth (Đăng nhập với Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# PayPal (Sandbox: https://developer.paypal.com/dashboard/applications/sandbox)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Phí ship theo khoảng cách: tọa độ kho / điểm lấy hàng (mặc định: Hà Nội)
SHIPPING_WAREHOUSE_LAT=21.028511
SHIPPING_WAREHOUSE_LNG=105.854204
